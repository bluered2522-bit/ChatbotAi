<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg"
        android:elevation="4dp"
        app:title="@string/settings_title"
        app:titleTextColor="@color/text_primary"
        app:navigationIcon="@drawable/ic_close" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CARD 1: API KEY -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_bubble_ai"
                android:padding="18dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/section_api_key"
                    android:textColor="@color/text_on_surface"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_field_flat"
                    android:hint="@string/api_key_hint"
                    android:inputType="textPassword"
                    android:paddingHorizontal="14dp"
                    android:textColor="@color/text_on_surface"
                    android:textColorHint="@color/text_on_surface_secondary"
                    android:singleLine="true" />

            </LinearLayout>

            <!-- CARD 2: PILIH PROVIDER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_bubble_ai"
                android:padding="18dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/section_provider"
                    android:textColor="@color/text_on_surface"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <RadioGroup
                    android:id="@+id/radioGroupProvider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radioGemini"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/provider_gemini"
                        android:textColor="@color/text_on_surface"
                        android:textSize="15sp"
                        android:buttonTint="@color/accent"
                        android:paddingVertical="10dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/surface_border" />

                    <RadioButton
                        android:id="@+id/radioOpenAi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/provider_openai"
                        android:textColor="@color/text_on_surface"
                        android:textSize="15sp"
                        android:buttonTint="@color/accent"
                        android:paddingVertical="10dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/surface_border" />

                    <RadioButton
                        android:id="@+id/radioClaude"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/provider_claude"
                        android:textColor="@color/text_on_surface"
                        android:textSize="15sp"
                        android:buttonTint="@color/accent"
                        android:paddingVertical="10dp" />

                </RadioGroup>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/model_name_label"
                    android:textColor="@color/text_on_surface_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/spModel"
                        android:layout_width="match_parent"
                            android:layout_height="48dp"
                                android:layout_marginTop="8dp" />
                                

            </LinearLayout>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="4dp"
                android:backgroundTint="@color/accent"
                android:text="@string/save"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/toolbar_bg"
                android:text="@string/logout"
                android:textAllCaps="false"
                android:textColor="@color/error" />

        </LinearLayout>
    </ScrollView>
</LinearLayout> 
